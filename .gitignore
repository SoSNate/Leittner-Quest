.env
.env.*
!.env.example

# ── Local override / personal config files ────────────────────────
*.local
*.local.json
settings.local.*
config.local.*

# ── Node.js ───────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
package-lock.json.bak

# ── Build outputs ─────────────────────────────────────────────────
dist/
dist-ssr/
build/
.vite/
*.tsbuildinfo

# ── IDE / Editor ──────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.iml
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.history/
*.code-workspace

